<h1 class="main-title">Books</h1>
<!-- form_with部分 -->

<table>
  <thead>
    <tr>
      <th>Title</th>
      <th>Body</th>

 <tbody>
    <% @books.each do |book| %>
      <tr>
        <td><%= book.title %></td>
        <td><%= book.body %></td>
        <td class="link-start2"><%= link_to 'Show', book_path(book.id) %></td>
        <td class="link-start3"><%= link_to 'Edit', edit_book_path(book.id) %></td>
        <td class="link-start3"><%= link_to "	Destroy", book_path(book.id),  data: { turbo_method: :delete, turbo_confirm: "Are you sure ?" } %></td>
      </tr>
    <% end %>
  </tbody>
</table>

<h1>New book</h1>
<% if @book.errors.any? %>
  <div class="error_explanation">
  <%= @book.errors.count %>errors prohibited this book from being saved:
  <ul>
    <% @book.errors.full_messages.each do |message| %>
      <li><%= message %></li>
    <% end %>
  </ul>
  </div>
<% end %>
<%= form_with model: @book do |f| %>
  <h4>Title</h4>
  <%= f.text_field :title %>
	
  <h5>Body</h5>
  <%= f.text_area :body %>
	
  <p>
  <%= f.submit 'Create Book' %>
  </p>
<% end %>
